#!/usr/bin/env python3
"""
send_sound <sound_name>        — one-shot: scan, connect, send, disconnect
send_sound --daemon            — daemon:  scan+connect once, then read commands on stdin

In daemon mode the script prints "ready" once all devices are connected,
then reads one sound name per line on stdin and prints "success" or "error"
after each transfer.  Type "rescan" to re-scan for new devices.
Ctrl-C / EOF stops the daemon cleanly.
"""

import sys
import asyncio
import os
import time
from bleak import BleakScanner, BleakClient

SERVICE_UUID  = "12345678-1234-5678-1234-56789abcdef0"
WRITE_UUID    = "12345678-1234-5678-1234-56789abcdef1"  # CLI writes chunks here
NOTIFY_UUID   = "12345678-1234-5678-1234-56789abcdef2"  # app confirms here
SOUNDS_DIR    = os.path.join(os.path.dirname(__file__), "sounds")

# ── helpers ──────────────────────────────────────────────────────────────────

def log(msg: str):
    print(f"[send_sound] {msg}", file=sys.stderr)

def find_sound_file(name: str) -> str | None:
    for ext in (".mp3", ".wav", ".aac"):
        path = os.path.join(SOUNDS_DIR, name + ext)
        if os.path.isfile(path):
            return path
    return None

# ── DevicePool — persistent BLE connections ──────────────────────────────────

# Number of write-without-response calls before yielding to the event loop.
# This prevents overwhelming the BlueZ D-Bus buffer while keeping throughput high.
WRITE_BATCH_SIZE = 50

# 8-byte end sentinel — 0xFF 0x00 is forbidden in MPEG audio streams,
# making this sequence impossible to appear in valid MP3/WAV/AAC data.
END_SENTINEL = bytes([0xFF, 0x00, 0xDE, 0xAD, 0xBE, 0xEF, 0xCA, 0xFE])


class DevicePool:
    """Manages long-lived BLE connections to all discovered devices."""

    def __init__(self):
        # address -> (BleakClient, friendly_name, chunk_size)
        self._clients: dict[str, tuple[BleakClient, str, int]] = {}
        self._reconnect_tasks: dict[str, asyncio.Task] = {}
        # Track which clients already have notifications subscribed
        self._notified: set[str] = set()

    # -- connection management ------------------------------------------------

    async def connect_all(self):
        """Scan and connect to every device advertising our service UUID."""
        log("Scan BLE en cours (5s)...")
        devices = await BleakScanner.discover(timeout=5.0, service_uuids=[SERVICE_UUID])

        if not devices:
            log("Aucun appareil trouvé avec le service UUID")
            log("Scan de debug (sans filtre UUID, 3s)...")
            all_devices = await BleakScanner.discover(timeout=3.0)
            if all_devices:
                log(f"  {len(all_devices)} appareil(s) BLE visible(s):")
                for d in all_devices:
                    uuids = d.metadata.get("uuids", []) if d.metadata else []
                    log(f"    - {d.name or '(inconnu)'} @ {d.address}  UUIDs={uuids}")
            else:
                log("  Aucun appareil BLE visible du tout")
            return False

        log(f"{len(devices)} appareil(s) trouvé(s):")
        for d in devices:
            log(f"  - {d.name or '(inconnu)'} @ {d.address}")

        # Only connect devices we don't already have
        new_devices = [d for d in devices if d.address not in self._clients]
        if not new_devices:
            log("Tous les appareils sont déjà connectés")
            return True

        results = await asyncio.gather(
            *[self._connect_one(d.address, d.name or d.address) for d in new_devices],
            return_exceptions=True,
        )
        ok = sum(1 for r in results if r is True)
        log(f"{ok}/{len(new_devices)} nouvel(s) appareil(s) connecté(s) (total: {len(self._clients)})")
        return len(self._clients) > 0

    async def rescan(self):
        """Re-scan for new devices and connect any new ones found."""
        log("Re-scan BLE en cours...")
        return await self.connect_all()

    async def _connect_one(self, address: str, name: str) -> bool:
        """Connect to a single device and keep the client alive."""
        try:
            log(f"  [{name}] Connexion à {address}...")
            client = BleakClient(
                address,
                timeout=15.0,
                disconnected_callback=lambda c: self._on_disconnect(address, name),
            )
            await client.connect(timeout=15.0)

            # Force MTU negotiation on BlueZ (fixes default MTU=23)
            try:
                await client._backend._acquire_mtu()
            except Exception:
                pass  # Fallback: use whatever MTU is available
            mtu = client.mtu_size
            chunk_size = max(mtu - 3, 20)
            log(f"  [{name}] Connecté, MTU={mtu}, chunk_size={chunk_size}")

            self._clients[address] = (client, name, chunk_size)

            # Subscribe to notifications once and keep them active
            await self._ensure_notify(address, client, name)

            return True
        except Exception as e:
            log(f"  [{name}] Erreur connexion: {type(e).__name__}: {e}")
            return False

    def _on_disconnect(self, address: str, name: str):
        """Called when a device disconnects unexpectedly — schedule reconnect."""
        log(f"  [{name}] Déconnecté inattendu, reconnexion en arrière-plan...")
        self._clients.pop(address, None)
        self._notified.discard(address)
        # Cancel any previous reconnect attempt for this device
        old_task = self._reconnect_tasks.pop(address, None)
        if old_task and not old_task.done():
            old_task.cancel()
        try:
            loop = asyncio.get_running_loop()
            task = loop.create_task(self._reconnect_loop(address, name))
            self._reconnect_tasks[address] = task
        except RuntimeError:
            pass  # loop already closed — we're shutting down

    async def _reconnect_loop(self, address: str, name: str):
        """Try to reconnect with exponential back-off (5s, 10s, 20s … 60s)."""
        delay = 5
        while True:
            log(f"  [{name}] Tentative de reconnexion dans {delay}s...")
            await asyncio.sleep(delay)
            ok = await self._connect_one(address, name)
            if ok:
                log(f"  [{name}] Reconnexion réussie!")
                self._reconnect_tasks.pop(address, None)
                return
            delay = min(delay * 2, 60)

    async def disconnect_all(self):
        """Cleanly disconnect every device."""
        # Cancel reconnect tasks first
        for task in self._reconnect_tasks.values():
            task.cancel()
        self._reconnect_tasks.clear()

        for address, (client, name, _) in list(self._clients.items()):
            try:
                # Remove disconnect callback to avoid triggering reconnect
                client.set_disconnected_callback(None)
                if address in self._notified:
                    await client.stop_notify(NOTIFY_UUID)
                await client.disconnect()
                log(f"  [{name}] Déconnecté proprement")
            except Exception:
                pass
        self._clients.clear()
        self._notified.clear()

    # -- notification management ----------------------------------------------

    async def _ensure_notify(self, address: str, client: BleakClient, name: str):
        """Subscribe to notifications once; handler is set per-transfer."""
        if address not in self._notified:
            # Use a no-op handler initially; replaced before each transfer
            await client.start_notify(NOTIFY_UUID, lambda _, __: None)
            self._notified.add(address)
            log(f"  [{name}] Notifications souscrites")

    # -- data transfer --------------------------------------------------------

    async def send_to_all(self, data: bytes) -> bool:
        """Send audio data to every connected device. Returns True if all ok."""
        if not self._clients:
            log("Aucun appareil connecté")
            return False

        results = await asyncio.gather(
            *[
                self._send_to_one(address, client, name, chunk_size, data)
                for address, (client, name, chunk_size) in list(self._clients.items())
            ],
            return_exceptions=True,
        )
        successes = sum(1 for r in results if r is True)
        failures = len(results) - successes
        if failures:
            log(f"{failures}/{len(results)} envoi(s) échoué(s)")
        else:
            log("Tous les envois réussis")
        return failures == 0

    async def _send_to_one(
        self, address: str, client: BleakClient, name: str,
        chunk_size: int, data: bytes,
    ) -> bool:
        result_event = asyncio.Event()
        success_flag = [False]

        def on_notify(_, value: bytearray):
            msg = bytes(value).decode("utf-8", errors="replace")
            log(f"  [{name}] confirmation reçue: {msg!r}")
            if value == b"ok":
                success_flag[0] = True
            result_event.set()

        try:
            if not client.is_connected:
                log(f"  [{name}] Non connecté, tentative de reconnexion...")
                ok = await self._connect_one(address, name)
                if not ok:
                    return False
                client, name, chunk_size = self._clients[address]

            # Re-subscribe with the transfer-specific handler
            # (stop + start to replace the callback)
            if address in self._notified:
                await client.stop_notify(NOTIFY_UUID)
                self._notified.discard(address)
            await client.start_notify(NOTIFY_UUID, on_notify)
            self._notified.add(address)

            # ── send size header (8 bytes, little-endian int64) ────────
            # The phone uses this to detect packet loss.
            import struct
            total = len(data)
            header = struct.pack("<q", total)
            await client.write_gatt_char(WRITE_UUID, header, response=False)
            await asyncio.sleep(0)  # let BlueZ flush before data burst

            # ── send data in chunks ──────────────────────────────────────────
            sent = 0
            chunk_count = 0
            t0 = time.monotonic()

            for i in range(0, total, chunk_size):
                chunk = data[i:i + chunk_size]
                await client.write_gatt_char(WRITE_UUID, chunk, response=False)
                sent += len(chunk)
                chunk_count += 1
                if chunk_count % WRITE_BATCH_SIZE == 0:
                    await asyncio.sleep(0)

            t_send = time.monotonic() - t0
            speed = (sent / 1024) / t_send if t_send > 0 else 0
            log(f"  [{name}] {sent}/{total} octets envoyés en {t_send:.2f}s "
                f"({speed:.1f} KB/s, {chunk_count} chunks), envoi sentinel...")

            # Safe 8-byte sentinel — impossible in valid MP3/WAV/AAC data.
            await client.write_gatt_char(WRITE_UUID, END_SENTINEL, response=False)

            t1 = time.monotonic()
            log(f"  [{name}] En attente de confirmation (max 30s)...")
            await asyncio.wait_for(result_event.wait(), timeout=30.0)
            t_confirm = time.monotonic() - t1
            log(f"  [{name}] Confirmation reçue en {t_confirm:.2f}s "
                f"(total: {time.monotonic() - t0:.2f}s)")

        except asyncio.TimeoutError:
            log(f"  [{name}] Timeout en attente de confirmation")
            return False
        except Exception as e:
            log(f"  [{name}] Erreur: {type(e).__name__}: {e}")
            return False

        return success_flag[0]

# ── one-shot mode (original behaviour) ───────────────────────────────────────

async def oneshot(sound_name: str):
    """Original behaviour: scan, connect, send, disconnect."""
    sound_path = find_sound_file(sound_name)
    if sound_path is None:
        log(f"Aucun fichier trouvé pour '{sound_name}' dans {SOUNDS_DIR}")
        print("error")
        sys.exit(1)

    with open(sound_path, "rb") as f:
        data = f.read()
    log(f"Fichier: {sound_path} ({len(data)} octets)")

    pool = DevicePool()
    if not await pool.connect_all():
        print("error")
        sys.exit(1)

    ok = await pool.send_to_all(data)
    await pool.disconnect_all()

    if ok:
        print("success")
    else:
        print("error")
        sys.exit(1)

# ── daemon mode ──────────────────────────────────────────────────────────────

async def daemon():
    """Long-running mode: connect once, then read sound names from stdin."""
    pool = DevicePool()
    if not await pool.connect_all():
        log("Impossible de se connecter à un appareil, abandon")
        print("error")
        sys.exit(1)

    print("ready", flush=True)
    log("Mode daemon prêt — tapez un nom de son par ligne, 'rescan' pour re-scanner (Ctrl-C pour quitter)")

    loop = asyncio.get_running_loop()
    reader = asyncio.StreamReader()
    protocol = asyncio.StreamReaderProtocol(reader)
    await loop.connect_read_pipe(lambda: protocol, sys.stdin)

    try:
        while True:
            line = await reader.readline()
            if not line:  # EOF
                break
            command = line.decode().strip()
            if not command:
                continue

            # ── rescan command ──
            if command == "rescan":
                await pool.rescan()
                n = len(pool._clients)
                log(f"Rescan terminé — {n} appareil(s) connecté(s)")
                print(f"rescan:{n}", flush=True)
                continue

            # ── send sound ──
            sound_name = command
            sound_path = find_sound_file(sound_name)
            if sound_path is None:
                log(f"Aucun fichier trouvé pour '{sound_name}' dans {SOUNDS_DIR}")
                print("error", flush=True)
                continue

            with open(sound_path, "rb") as f:
                data = f.read()
            log(f"Fichier: {sound_path} ({len(data)} octets)")

            ok = await pool.send_to_all(data)
            print("success" if ok else "error", flush=True)

    except (KeyboardInterrupt, asyncio.CancelledError):
        pass
    finally:
        log("Arrêt du daemon...")
        await pool.disconnect_all()

# ── entry point ──────────────────────────────────────────────────────────────

async def main():
    if len(sys.argv) < 2:
        print("Usage: send_sound <sound_name>", file=sys.stderr)
        print("       send_sound --daemon", file=sys.stderr)
        sys.exit(1)

    if sys.argv[1] == "--daemon":
        await daemon()
    else:
        await oneshot(sys.argv[1])

if __name__ == "__main__":
    asyncio.run(main())
